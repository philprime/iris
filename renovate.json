{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "extends": [
    "config:recommended"
  ],
  "keepUpdatedLabel": "renovate:keep-updated",
  "lockFileMaintenance": {
    "automerge": false,
    "enabled": true,
    "extends": [
      "schedule:weekly"
    ]
  },
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "automerge": false,
      "matchUpdateTypes": [
        "major"
      ]
    },
    {
      "description": "Keep Go version in go.mod up to date automatically",
      "matchManagers": [
        "gomod"
      ],
      "matchDepNames": [
        "go"
      ],
      "matchDepTypes": [
        "golang"
      ],
      "minimumReleaseAge": "0 days",
      "prPriority": 10,
      "rangeStrategy": "bump",
      "automerge": true
    },
    {
      "description": "Group Go toolchain updates (golang Docker image + go directive in go.mod) into a single PR",
      "groupName": "go toolchain",
      "matchDatasources": [
        "docker",
        "golang-version"
      ],
      "matchDepNames": [
        "go",
        "golang"
      ],
      "minimumReleaseAge": "0 days",
      "prPriority": 10,
      "automerge": true
    },
    {
      "description": "Group the boky/postfix ingress image updates",
      "groupName": "postfix ingress",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "boky/postfix"
      ]
    }
  ],
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths"
  ],
  "pre-commit": {
    "enabled": true
  },
  "rebaseLabel": "renovate:rebase",
  "schedule": [
    "* 1-4 * * 0,1,6"
  ],
  "stopUpdatingLabel": "renovate:disabled",
  "timezone": "Europe/Vienna"
}
